{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchManagers": ["cargo"],
      "groupName": "Rust dependencies",
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "matchManagers": ["pep621"],
      "groupName": "Python dev dependencies",
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "matchDepNames": ["python"],
      "enabled": false
    }
  ]
}
